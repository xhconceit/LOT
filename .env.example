# PostgreSQL（dev）
POSTGRES_DB=lot
POSTGRES_USER=lot
POSTGRES_PASSWORD=change-me

# deps 启动策略（dev）：local | docker | auto
LOT_DEPS_MODE=auto

# api-service
PORT=3000
DATABASE_URL=postgres://user:pass@localhost:5432/lot
JWT_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:5173

# ingest-worker
MQTT_URL=mqtt://localhost:1883

# mqtt-broker
MQTT_PORT=1883

# admin-web（Vite）
VITE_API_BASE_URL=http://localhost:3000/api/v1
